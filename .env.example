# Core app
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Professional monthly ($61 USD / £49 GBP)
VITE_STRIPE_PRICE_PROFESSIONAL_USD=
VITE_STRIPE_PRICE_PROFESSIONAL_GBP=

# Producer monthly ($149 USD / £119 GBP)
VITE_STRIPE_PRICE_PRODUCER_USD=
VITE_STRIPE_PRICE_PRODUCER_GBP=

# Studio monthly ($299 USD / £239 GBP)
VITE_STRIPE_PRICE_STUDIO_USD=
VITE_STRIPE_PRICE_STUDIO_GBP=

# Annual plans GBP (£39/mo, £95/mo, £199/mo billed yearly)
VITE_STRIPE_PRICE_PROFESSIONAL_ANNUAL_GBP=
VITE_STRIPE_PRICE_PRODUCER_ANNUAL_GBP=
VITE_STRIPE_PRICE_STUDIO_ANNUAL_GBP=

# Annual plans USD ($49/mo, $119/mo, $239/mo billed yearly)
VITE_STRIPE_PRICE_PROFESSIONAL_ANNUAL_USD=
VITE_STRIPE_PRICE_PRODUCER_ANNUAL_USD=
VITE_STRIPE_PRICE_STUDIO_ANNUAL_USD=

# API keys (client-exposed if prefixed with VITE_)
VITE_GOOGLE_MAPS_API_KEY=
VITE_TMDB_API_KEY=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
VITE_EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_BASE_URL=https://api.exchangerate-api.com/v4
VITE_RECAPTCHA_SITE_KEY=

# Analytics
VITE_GA4_MEASUREMENT_ID=
VITE_MIXPANEL_TOKEN=

# Error monitoring (Sentry) — leave VITE_SENTRY_DSN empty to disable.
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Optional external integrations
BLS_API_KEY=
GRANTIFY_API_KEY=
GRANTIFY_AFFILIATE_ID=
ONS_API_KEY=
STATCAN_API_KEY=
ABS_API_KEY=
STATSNZ_API_KEY=

# Feature flags
VITE_ENABLE_STRIPE_PAYMENTS=true
VITE_ENABLE_PDF_GENERATION=true
VITE_ENABLE_EMAIL_NOTIFICATIONS=false
VITE_ENABLE_GRANTIFY_INTEGRATION=false
VITE_ENABLE_FESTIVAL_TRACKING=false

# Existing deployment/legacy vars referenced in docs or config
VITE_OPENAI_API_KEY=
VITE_AWS_S3_BUCKET=
VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=
VITE_AWS_SECRET_ACCESS_KEY=
